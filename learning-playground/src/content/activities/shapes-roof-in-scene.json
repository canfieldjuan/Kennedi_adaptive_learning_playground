{
  "id": "shapes-roof-in-scene",
  "version": 1,
  "title": "Roof Shape Match",
  "domain": "spatial",
  "skill_ids": ["shape_match"],
  "originating_brief_id": "brief-shape_match-different_prompt_mode",
  "transfer": {
    "skill_ids": ["shape_match"],
    "context_type": "different_prompt_mode",
    "context_id": "identify-shape-in-scene",
    "example_set_id": "little-house-roof-1",
    "prompt_mode": "mixed"
  },
  "difficulty": {
    "level": 4,
    "choice_count": 3,
    "distractor_strength": "medium"
  },
  "interaction_model": "tap_to_match",
  "estimated_duration_seconds": 60,
  "content": {
    "prompt_audio": "Look at the little house. What shape is the roof?",
    "prompt_visual_layout": "scene",
    "prompt_scene": {
      "image": "/assets/images/shape-house-scene.svg",
      "target_object_label": "roof",
      "target_shape_id": "triangle"
    },
    "prompt_images": [
      "/assets/images/shape-house-scene.svg"
    ],
    "target_shape": "triangle",
    "choices": [
      {
        "id": "circle",
        "label": "circle",
        "image": "/assets/images/circle.svg",
        "correct": false
      },
      {
        "id": "square",
        "label": "square",
        "image": "/assets/images/square.svg",
        "correct": false
      },
      {
        "id": "triangle",
        "label": "triangle",
        "image": "/assets/images/triangle.svg",
        "correct": true
      }
    ]
  },
  "success_rules": {
    "correct_choice_id": "triangle",
    "required_correct_count": 1,
    "max_attempts_before_hint": 2
  },
  "feedback_rules": {
    "correct": {
      "speech": "Yes. The roof is a triangle.",
      "animation": "glow_pop",
      "sound": "soft_chime"
    },
    "incorrect": {
      "speech": "Look at the roof shape and try again.",
      "animation": "gentle_bounce",
      "sound": "soft_boing"
    },
    "hint": {
      "speech": "Trace the roof's three sides with your eyes.",
      "highlight_target": true
    }
  },
  "safety": {
    "requires_parent_approval": true,
    "external_links_allowed": false,
    "contains_video": false,
    "contains_audio": true
  }
